2) Sieve of Eratosthenes (efficient for listing primes up to N)

- Runs in O(n log log n) time.
- Great for generating all primes up to a limit.

Code:

package main

import "fmt"

func sieve(n int) []int {
    if n < 2 {
        return []int{}
    }
    isPrime := make([]bool, n+1)
    for i := 2; i <= n; i++ {
        isPrime[i] = true
    }
    for p := 2; p*p <= n; p++ {
        if isPrime[p] {
            for multiple := p * p; multiple <= n; multiple += p {
                isPrime[multiple] = false
            }
        }
    }
    primes := []int{}
    for i := 2; i <= n; i++ {
        if isPrime[i] {
            primes = append(primes, i)
        }
    }
    return primes
}

func main() {
    fmt.Println(sieve(100))
}

